<!-- gradient def (available if an icon opts into url(#g) stroke) -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true">
  <defs>
    <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#FF8C42" />
      <stop offset="52%" stop-color="#17BEBB" />
      <stop offset="100%" stop-color="#5B53E8" />
    </linearGradient>
  </defs>
</svg>

<script>
  // ── Scroll reveal ──────────────────────────────────────────────────────
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) { entry.target.classList.add("is-visible"); observer.unobserve(entry.target); }
      });
    },
    { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
  );
  document.querySelectorAll("[data-reveal]").forEach((el) => observer.observe(el));

  // ── Demo videos: lazy-load + autoplay the theme-matching clip when in view ─
  (function () {
    var vids = Array.prototype.slice.call(document.querySelectorAll("video[data-demo]"));
    if (!vids.length) return;
    var reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    function theme() { return document.documentElement.getAttribute("data-theme") === "dark" ? "dark" : "light"; }
    function asset(name, t, ext) { return "/demos/" + name + "-" + t + "." + ext; }
    function sources(v, t) {
      v.querySelector("source[data-webm]").src = asset(v.getAttribute("data-demo"), t, "webm");
      v.querySelector("source[data-mp4]").src = asset(v.getAttribute("data-demo"), t, "mp4");
      v.load();
    }
    function poster(v) {
      var t = theme();
      if (v.getAttribute("data-poster-theme") === t) return;
      v.setAttribute("data-poster-theme", t);
      v.setAttribute("poster", asset(v.getAttribute("data-demo"), t, "poster.jpg"));
    }
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        var v = e.target;
        if (e.isIntersecting) {
          poster(v);
          if (!reduce) {
            if (v.dataset.live !== "1") { v.dataset.live = "1"; sources(v, theme()); }
            v.play().catch(function () {});
          }
        } else if (!reduce) { v.pause(); }
      });
    }, { rootMargin: "300px 0px", threshold: 0.15 });
    vids.forEach(function (v) { io.observe(v); });

    new MutationObserver(function () {
      vids.forEach(function (v) {
        if (v.getAttribute("data-poster-theme")) poster(v);
        if (v.dataset.live === "1") { sources(v, theme()); if (!reduce) v.play().catch(function () {}); }
      });
    }).observe(document.documentElement, { attributes: true, attributeFilter: ["data-theme"] });
  })();

  // ── Smooth scroll + focus the pilot form from CTAs ─────────────────────
  document.querySelectorAll('a[href="#pilot"]').forEach(function (a) {
    a.addEventListener("click", function () {
      setTimeout(function () {
        var input = document.querySelector('#form-pilot input[name="name"]');
        if (input) input.focus({ preventScroll: true });
      }, 600);
    });
  });
  document.getElementById("workshop-link")?.addEventListener("click", function (e) {
    e.preventDefault();
    var pain = document.querySelector('#form-pilot textarea[name="pain"]');
    document.getElementById("pilot")?.scrollIntoView({ behavior: "smooth" });
    if (pain) { setTimeout(function () { pain.value = "I'd like to start with a workshop."; pain.focus({ preventScroll: true }); }, 600); }
  });
</script>

<!-- Pilot form submission (posts to Supabase; graceful no-op if unconfigured) -->
<script define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
  // Requires a Supabase table `pilot_leads` with columns:
  //   name text, company text, role text, email text, phone text, pain text
  // (and an RLS policy allowing anon inserts, like the existing waitlist table).
  async function submitPilot(payload) {
    if (!supabaseUrl || !supabaseKey) {
      console.error("[pilot] Supabase config missing - set PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY at build time.");
      return false;
    }
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 15000);
    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/pilot_leads`, {
        method: "POST",
        headers: {
          apikey: supabaseKey,
          Authorization: `Bearer ${supabaseKey}`,
          "Content-Type": "application/json",
          Prefer: "return=minimal",
        },
        body: JSON.stringify(payload),
        signal: controller.signal,
      });
      if (res.ok || res.status === 201 || res.status === 409) return true;
      console.error(`[pilot] insert failed: ${res.status} ${res.statusText}`, await res.text().catch(() => ""));
      return false;
    } catch (err) {
      console.error("[pilot] request failed:", err);
      return false;
    } finally {
      clearTimeout(timeout);
    }
  }

  (function () {
    const form = document.getElementById("form-pilot");
    const success = document.getElementById("success-pilot");
    if (!form) return;
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form).entries());
      if (!data.name || !data.company || !data.email) {
        const first = form.querySelector("input[required]");
        if (first) first.focus();
        return;
      }
      const btn = form.querySelector('button[type="submit"]');
      btn.disabled = true;
      const label = btn.textContent;
      btn.textContent = "Sending…";
      const ok = await submitPilot(data);
      if (ok) {
        form.querySelectorAll(".pf-row, .pf-field, .pf-submit").forEach((el) => { el.style.display = "none"; });
        if (success) success.hidden = false;
      } else {
        btn.disabled = false;
        btn.textContent = "Try again";
        setTimeout(() => { btn.textContent = label; }, 2500);
      }
    });
  })();
</script>
