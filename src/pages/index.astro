  }
  .journey-wrap-label .wrap-icon { display: inline-flex; color: var(--amber-500); }
  .journey-wrap-label .wrap-icon :global(svg) { width: 16px; height: 16px; }
  .journey-steps { display: flex; flex-direction: column; gap: 8px; align-items: stretch; }
  .journey-step {
    flex: 1; background: var(--surface-subtle); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 22px; position: relative; text-align: center;
  }
  .journey-step .journey-n {
    font-family: var(--font-mono); font-size: 0.7rem; font-weight: 600; color: var(--text-muted); letter-spacing: 0.08em;
  }
  .journey-icon { display: inline-flex; margin: 10px 0 8px; }
