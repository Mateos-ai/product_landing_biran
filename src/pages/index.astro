  .journey-step p { font-size: 0.88rem; color: var(--text-secondary); line-height: 1.55; }
  .jstep-amber .journey-icon { color: var(--amber-500); }
  .jstep-teal .journey-icon { color: var(--teal-500); }
  .jstep-indigo .journey-icon { color: var(--indigo-500); }
  .jstep-gradient {
    border-color: transparent;
    background:
      linear-gradient(var(--surface-subtle), var(--surface-subtle)) padding-box,
      var(--gradient-brand) border-box;
  }
