</Layout>

<style>
  /* ── Navbar ──────────────────────────────────────────────────────────── */
  header {
    position: sticky; top: 0; z-index: 50;
    background: var(--nav-bg);
    backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--nav-border);
  }
  .bar { display: flex; align-items: center; justify-content: space-between; height: 64px; gap: 24px; }
  .brand { display: flex; align-items: center; gap: 10px; }
  .brand-mark { height: 28px; width: auto; }
  .brand-name { font-family: var(--font-display); font-weight: 700; font-size: 1rem; letter-spacing: -0.02em; color: var(--text-primary); }
  .brand-ai { color: var(--amber-500); }
  .nav-links { display: none; gap: 28px; margin-inline-start: auto; }
  .nav-links a { font-size: 0.9rem; font-weight: 500; color: var(--text-secondary); transition: color 0.15s; }
  .nav-links a:hover { color: var(--text-primary); }
