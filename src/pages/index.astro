<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => observer.observe(el));

  // -- Demo videos: lazy-load + autoplay the theme-matching clip when in view ----
  (function () {
    var vids = Array.prototype.slice.call(document.querySelectorAll('video[data-demo]'));
    if (!vids.length) return;
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    function theme() { return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'light'; }
    function asset(name, t, ext) { return '/demos/' + name + '-' + t + '.' + ext; }
    function sources(v, t) {
      var name = v.getAttribute('data-demo');
      v.querySelector('source[data-webm]').src = asset(name, t, 'webm');
      v.querySelector('source[data-mp4]').src = asset(name, t, 'mp4');
      v.load();
    }
    function poster(v) {
      var t = theme();
      if (v.getAttribute('data-poster-theme') === t) return;
      v.setAttribute('data-poster-theme', t);
      v.setAttribute('poster', asset(v.getAttribute('data-demo'), t, 'poster.jpg'));
    }

    // Everything is below the fold, so nothing loads until it nears the viewport:
    // the poster streams in first (tiny, and all a reduced-motion user needs), then
    // the clip. This keeps the initial page load free of demo bytes.
    var io = new IntersectionObserver(function (entries) {
      entries.forEach(function (e) {
        var v = e.target;
        if (e.isIntersecting) {
          poster(v);
          if (!reduce) {
            if (v.dataset.live !== '1') { v.dataset.live = '1'; sources(v, theme()); }
            v.play().catch(function () {});
          }
        } else if (!reduce) { v.pause(); }
      });
    }, { rootMargin: '300px 0px', threshold: 0.15 });
    vids.forEach(function (v) { io.observe(v); });

    // follow the theme toggle: reset the poster and (if already loaded) reload sources
    new MutationObserver(function () {
      vids.forEach(function (v) {
        if (v.getAttribute('data-poster-theme')) poster(v);
        if (v.dataset.live === '1') { sources(v, theme()); if (!reduce) v.play().catch(function () {}); }
      });
    }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
  })();


  // ── Demo cards: self-playing looping demos driven by a fake cursor ──────
  (function () {
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;   // reduced-motion / no-JS users see the static authored cards

    var TYPING_MS = 950;      // typing-dots dwell before the message
    var CHAR_MS = 45;         // per-character typing speed
    var ROW_MS = 220;         // stagger between card rows
    var CARD_GAP_MS = 600;    // pause between the message landing and the card building
    var CARD_LOADER_MS = 1300;// optional "preparing" loader beat before a card builds
    var HOLD_MS = 2600;       // dwell on the finished state before the demo loops
    var CURSOR_MOVE_MS = 720; // must match the .demo-cursor transform transition
    var CURSOR = '<span class="tw-cursor">|</span>';

    // how long each auto-clicked action takes to play out before we loop
    var ACTION_MS = {
      prep: 4400, sync: 4800, execute: 3600, propose: 4600,
      'execute-send': 2600, automate: 2200, approve: 2400,
      oversight: 1500, 'rule-opt': 1400
    };

    // a classic pointer arrow, filled with the brand orange
    var CURSOR_SVG = '<svg width="15" height="15" viewBox="0 0 24 24" aria-hidden="true"><path d="M5 2.2 L5 19.6 L9.3 15.4 L12.1 21.6 L14.9 20.4 L12.1 14.4 L18.4 14.4 Z"/></svg>';

    var panels = document.querySelectorAll('.pin-panel');
    for (var i = 0; i < panels.length; i++) setupCard(panels[i]);

    function setupCard(panel) {
      var windowEl = panel.querySelector('.pin-window');
      var body = panel.querySelector('.pin-window-body');
      if (!windowEl || !body) return;

      // Pristine authored markup - restored on every loop so the demo replays
      // from scratch (typed message, empty chips, un-sent emails, off toggles…).
      var originalHTML = body.innerHTML;

      // one fake cursor per card window; it lives outside `body` so the innerHTML
      // reset between loops never removes it
      var cursor = document.createElement('span');
      cursor.className = 'demo-cursor';
      cursor.setAttribute('aria-hidden', 'true');
      cursor.innerHTML = CURSOR_SVG;
      windowEl.appendChild(cursor);

      var token = 0;
      var running = false;
      var timers = [];
      function wait(ms, fn) { var t = setTimeout(fn, ms); timers.push(t); return t; }
      function clearTimers() { for (var i = 0; i < timers.length; i++) clearTimeout(timers[i]); timers = []; }
      function hideCursor() { cursor.style.opacity = '0'; cursor.classList.remove('is-click'); }

      function reset() {
        clearTimers();
        body.innerHTML = originalHTML;   // event handling is delegated on <main>, so this is safe
        hideCursor();
      }

      // start at the component's centre, then glide to the element and "click" it
      function moveCursorTo(el, cb) {
        var wr = windowEl.getBoundingClientRect();
        var er = el.getBoundingClientRect();
        var x = (er.left - wr.left) + er.width / 2;
        var y = (er.top - wr.top) + er.height / 2;
        // jump to the centre with no animation, then transition over to the target
        cursor.style.transition = 'none';
        cursor.style.transform = 'translate(' + (wr.width / 2) + 'px, ' + (wr.height / 2) + 'px)';
        cursor.style.opacity = '1';
        void cursor.offsetWidth;          // commit the centre position before animating
        cursor.style.transition = '';     // restore the transition from the stylesheet
        requestAnimationFrame(function () {
          cursor.style.transform = 'translate(' + x + 'px, ' + y + 'px)';
        });
        wait(CURSOR_MOVE_MS + 120, function () {
          cursor.classList.add('is-click');
          wait(240, function () { cursor.classList.remove('is-click'); if (cb) cb(); });
        });
      }

      // the one control this card's demo should auto-click (null = display only)
      function primaryTarget() {
        var sel = '[data-action="prep"],[data-action="sync"],[data-action="execute"],' +
                  '[data-action="propose"],[data-action="execute-send"],[data-action="automate"],' +
                  '[data-action="approve"],[data-action="oversight"]';
        var t = body.querySelector(sel);
        if (t) return t;
        // "You Set the Rules": flip the first row's segmented control over to Auto
        var seg = body.querySelector('[data-seg]');
        if (seg) {
          var opts = seg.querySelectorAll('[data-action="rule-opt"]');
          return opts.length > 1 ? opts[1] : null;
        }
        return null;
      }
      function actionMs(el) { return ACTION_MS[el.getAttribute('data-action')] || 2500; }

      // ── the intro stream: typing dots → typewriter greeting → card builds ──
      function playStream(my, done) {
        var root = body.querySelector('[data-brief-stream]');
        if (!root) { done(); return; }   // control cards have no stream - show statically
        var typingEl = root.querySelector('[data-brief-typing]');
        var greetMsg = root.querySelector('[data-brief-greeting-msg]');
        var greetEl = root.querySelector('[data-brief-greeting]');
        var cardLoader = root.querySelector('[data-brief-cardloader]');
        var card = root.querySelector('[data-brief-card]');
        var rows = root.querySelectorAll('[data-brief-row]');
        if (!typingEl || !greetEl || !card) { done(); return; }
        var chars = Array.from(greetEl.textContent);   // grapheme-safe (keeps ☀️/🌙 intact)

        typingEl.hidden = false;
        greetMsg.hidden = true;
        greetEl.textContent = '';
        if (cardLoader) cardLoader.hidden = true;
        // keep the card in layout (opacity only) so its height is reserved from
        // the start - in normal flow, display:none → block would jump the page
        card.classList.add('bm-stream-hide');
        card.classList.remove('bm-stream-show');
        for (var i = 0; i < rows.length; i++) {
          rows[i].classList.add('bm-stream-hide');
          rows[i].classList.remove('bm-stream-show');
        }

        wait(TYPING_MS, function () {
          if (my !== token) return;
          typingEl.hidden = true;
          greetMsg.hidden = false;
          typeChar(0);
        });

        function typeChar(i) {
          if (my !== token) return;
          if (i <= chars.length) {
            greetEl.innerHTML = chars.slice(0, i).join('') + CURSOR;
            wait(CHAR_MS, function () { typeChar(i + 1); });
          } else {
            greetEl.textContent = chars.join('');   // drop the cursor
            if (cardLoader) {
              cardLoader.hidden = false;
              wait(CARD_LOADER_MS, function () { if (my !== token) return; cardLoader.hidden = true; revealCard(); });
            } else {
              wait(CARD_GAP_MS, revealCard);
            }
          }
        }
        function revealCard() {
          if (my !== token) return;
          card.classList.remove('bm-stream-hide');
          card.classList.add('bm-stream-show');
          revealRows(0);
        }
        function revealRows(i) {
          if (my !== token) return;
          if (i >= rows.length) { done(); return; }
          rows[i].classList.remove('bm-stream-hide');
          rows[i].classList.add('bm-stream-show');
          wait(ROW_MS, function () { revealRows(i + 1); });
        }
      }

      // ── one loop: reset → stream in → cursor clicks the action → hold → repeat ──
      function cycle() {
        var my = ++token;
        reset();
        playStream(my, function () {
          if (my !== token) return;
          var target = primaryTarget();
          if (target) {
            wait(450, function () {
              if (my !== token) return;
              moveCursorTo(target, function () {
                if (my !== token) return;
                target.click();
                wait(actionMs(target), finish);
              });
            });
          } else {
            wait(900, finish);
          }
        });
        function finish() {
          if (my !== token) return;
          hideCursor();
          wait(HOLD_MS, function () { if (my === token && running) cycle(); });
        }
      }

      function start() { if (running) return; running = true; cycle(); }
      function stop() { running = false; token++; clearTimers(); reset(); }

      // only play once the whole browser mockup is in view; pause + reset otherwise
      new IntersectionObserver(function (entries) {
        var e = entries[0];
        if (e.isIntersecting && e.intersectionRatio >= 0.95) start(); else stop();
      }, { threshold: [0, 0.95, 1] }).observe(windowEl);
    }
  })();

  // ── Pinned sections: interactive demo-card actions (local only) ─────────
  (function () {
    var root = document.querySelector('main');
    if (!root) return;

    var PREP_STEPS = [
      'Reading the event description',
      'Analyzing the participants',
      'Reading company info in CRM',
      'Gathering everything',
      'Writing summary'
    ];
    var PREP_LINE_MS = 700;

    root.addEventListener('click', function (e) {
      var btn = e.target.closest('[data-action]');
      if (!btn || btn.classList.contains('is-busy')) return;
      var action = btn.getAttribute('data-action');
      if (action === 'prep') runPrep(btn);
      else if (action === 'sync') runSync(btn);
      else if (action === 'execute') runExecute(btn);
      else if (action === 'backlog-close') backlogClose(btn);
      else if (action === 'backlog-review') backlogReview(btn);
      else if (action === 'propose') runPropose(btn);
      else if (action === 'execute-send') runSendFollowup(btn);
      else if (action === 'automate') runAutomate(btn);
      else if (action === 'approve') runApprove(btn, true);
      else if (action === 'hold') runApprove(btn, false);
      else if (action === 'rule-opt') runRuleOpt(btn);
      else if (action === 'oversight') runOversight(btn);
    });

    // keep the "Execute backlog" button in sync with the checkboxes
    root.addEventListener('change', function (e) {
      var box = e.target.closest('[data-task]');
      if (box) updateBacklog(box.closest('[data-backlog]'));
    });

    function runPrep(btn) {
      var card = btn.closest('[data-briefing]');
      if (!card) return;

      // idle → run the status-bar loading, then drop "Prep in email" on the row
      card.setAttribute('data-prep-state', 'loading');
      btn.classList.add('is-busy');
      btn.style.visibility = 'hidden';

      var bar = card.querySelector('[data-statusbar]');
      var fill = card.querySelector('[data-statusfill]');
      var text = card.querySelector('[data-statustext]');
      bar.hidden = false;
      fill.style.width = '0%';

      var i = 0;
      text.textContent = PREP_STEPS[0] + '…';
      // kick the bar to full over the whole sequence
      requestAnimationFrame(function () {
        fill.style.transition = 'width ' + (PREP_STEPS.length * PREP_LINE_MS) + 'ms linear';
        fill.style.width = '100%';
      });

      (function nextLine() {
        i++;
        if (i < PREP_STEPS.length) {
          text.textContent = PREP_STEPS[i] + '…';
          setTimeout(nextLine, PREP_LINE_MS);
        } else {
          setTimeout(function () {
            bar.hidden = true;
            // Acme joins the already-prepped meetings: button → "Prep in email" chip
            var wrap = btn.closest('.bm-press-wrap') || btn;
            wrap.hidden = true;
            var chip = card.querySelector('[data-emailed]');
            if (chip) chip.hidden = false;
            card.setAttribute('data-prep-state', 'emailed');
            // all three meetings prepped → nudge onward
            scrollHint();
          }, PREP_LINE_MS);
        }
      })();
    }

    function runSync(btn) {
      btn.classList.add('is-busy');
      btn.innerHTML = '<span class="bm-btn-spin"></span>Syncing…';
      var card = btn.closest('.bm-card');
      var fills = card.querySelectorAll('[data-fill]');
      var SYNC_STEP = 1350;     // time between fields
      var SYNC_RESOLVE = 1080;  // green liquid fills the gray loader, then the value resolves

      var status = card.querySelector('[data-sync-status]');
      if (status) { status.textContent = 'Syncing…'; }

      for (var i = 0; i < fills.length; i++) {
        (function (chip, idx) {
          setTimeout(function () {
            fillChip(chip, SYNC_RESOLVE, chip.getAttribute('data-value'));
          }, idx * SYNC_STEP);
        })(fills[i], i);
      }

      setTimeout(function () {
        if (status) {
          status.textContent = 'Synced';
          status.classList.remove('bm-chip-amber');
          status.classList.add('bm-chip-teal');
        }
        // terminal state: a confirmation, not a pressable button
        markDone(btn, 'Synced ✓');
        scrollHint(btn.closest('.bm-actions') || btn.parentNode);
      }, fills.length * SYNC_STEP + 450);
    }

    // turn an action button into a non-interactive "done" confirmation
    function markDone(btn, label) {
      btn.classList.remove('is-busy', 'bm-btn-primary', 'bm-hint-target');
      btn.classList.add('bm-btn-done');
      btn.disabled = true;
      if (label != null) btn.innerHTML = label;
    }

    // type text into a chat bubble: brief typing-dots beat, then a typewriter
    // reveal (grapheme-safe, blinking cursor) - like the card greetings
    function streamBubble(bubble, text, onDone) {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        bubble.textContent = text;
        if (onDone) onDone();
        return;
      }
      var chars = Array.from(text);   // keeps 🎉 intact
      var CURSOR = '<span class="tw-cursor">|</span>';
      bubble.classList.add('bm-typing');
      bubble.innerHTML = '<span></span><span></span><span></span>';
      setTimeout(function () {
        bubble.classList.remove('bm-typing');
        var i = 0;
        (function step() {
          i++;
          if (i <= chars.length) {
            bubble.innerHTML = chars.slice(0, i).join('') + CURSOR;
            setTimeout(step, 55);
          } else {
            bubble.textContent = chars.join('');
            if (onDone) onDone();
          }
        })();
      }, 700);
    }

    // run the gray→green "liquid" loader on a chip, then resolve it to `label`
    function fillChip(chip, resolveMs, label) {
      chip.classList.remove('bm-chip-empty');
      chip.classList.add('bm-chip-loading');
      chip.innerHTML = '<span class="bm-chip-bar"><span class="bm-chip-bar-fill"></span></span>';
      var f = chip.querySelector('.bm-chip-bar-fill');
      f.style.transition = 'width ' + resolveMs + 'ms linear';
      void f.offsetWidth;   // commit the 0% baseline so the fill actually animates
      f.style.width = '100%';
      setTimeout(function () {
        chip.classList.remove('bm-chip-loading');
        chip.classList.add('bm-chip-teal', 'is-filling');
        chip.textContent = label;
      }, resolveMs);
    }

    // The cards no longer pin/advance on scroll, so the "Keep scrolling" nudge
    // is gone. The demo action functions below still call scrollHint() at the
    // end of their sequence - keep it as a harmless no-op.
    function scrollHint() {}

    function backlogParts(node) {
      var root = node.closest ? node.closest('[data-backlog]') : node;
      return {
        root: root,
        card: root.querySelector('[data-backlog-card]'),
        collapsed: root.querySelector('[data-backlog-collapsed]'),
        followup: root.querySelector('[data-backlog-followup]'),
        summary: root.querySelector('[data-backlog-summary]'),
        count: root.querySelector('[data-backlog-count]'),
        execBtn: root.querySelector('[data-action="execute"]'),
        tasks: root.querySelectorAll('[data-task]')
      };
    }

    function taskDone(box) {
      var t = box.closest('.bm-task');
      return t && t.classList.contains('is-done');
    }

    // count tasks that are still actionable (checked and not already done)
    function countChecked(p) {
      var n = 0;
      for (var i = 0; i < p.tasks.length; i++) if (p.tasks[i].checked && !taskDone(p.tasks[i])) n++;
      return n;
    }

    function updateBacklog(root) {
      var p = backlogParts(root);
      var n = countChecked(p);
      if (p.count) p.count.textContent = n ? (n + ' selected') : 'none selected';
      if (p.execBtn) p.execBtn.disabled = (n === 0);
    }

    function collapseBacklog(root, summaryText, opts) {
      var p = backlogParts(root);
      opts = opts || {};
      if (p.summary) p.summary.textContent = summaryText;
      // green "all done" treatment
      p.collapsed.classList.toggle('is-complete', !!opts.complete);
      // hide the Review button once the backlog is fully executed - nothing to review
      var reviewBtn = p.collapsed.querySelector('[data-action="backlog-review"]');
      if (reviewBtn) reviewBtn.hidden = !!opts.complete;
      // swap the closing message - streamed in like a chat message
      var followText = p.followup.querySelector('[data-followup-text]');
      var msg = opts.complete ? 'Great job! You can go rest now 🎉' : 'Anything else then?';
      // success message gets the avatar-matched (indigo) tint
      if (followText) followText.classList.toggle('bm-bubble-indigo', !!opts.complete);
      p.card.hidden = true;
      p.collapsed.hidden = false;
      p.followup.hidden = false;
      if (followText) streamBubble(followText, msg);
      scrollHint(p.followup);
    }

    function runExecute(btn) {
      var p = backlogParts(btn);
      var n = countChecked(p);
      if (n === 0) return;
      btn.classList.add('is-busy');
      btn.innerHTML = '<span class="bm-btn-spin"></span>Executing…';

      var checked = [];
      for (var i = 0; i < p.tasks.length; i++) if (p.tasks[i].checked && !taskDone(p.tasks[i])) checked.push(p.tasks[i]);
      var STEP = 480;
      checked.forEach(function (box, idx) {
        setTimeout(function () {
          var task = box.closest('.bm-task');
          if (task) task.classList.add('is-done');
          box.disabled = true; // done tasks stay done; can't be toggled again
        }, idx * STEP);
      });
      setTimeout(function () {
        // report the actual total handled (everything currently done)
        var done = 0;
        for (var i = 0; i < p.tasks.length; i++) if (taskDone(p.tasks[i])) done++;
        var remaining = p.tasks.length - done;
        var complete = (remaining === 0);
        var summary = complete
          ? 'All executed. Backlog clear'
          : '✓ ' + done + (done === 1 ? ' task handled' : ' tasks handled') + ' · ' + remaining + ' left';
        collapseBacklog(p.root, summary, { complete: complete });
        btn.classList.remove('is-busy');
        btn.innerHTML = 'Execute backlog';
      }, checked.length * STEP + 350);
    }

    function backlogClose(btn) {
      collapseBacklog(btn.closest('[data-backlog]'), 'Backlog saved for later');
    }

    function backlogReview(btn) {
      var p = backlogParts(btn);
      p.collapsed.hidden = true;
      p.followup.hidden = true;
      // reopen exactly as the user left it: keep each checkbox state,
      // keep already-executed tasks marked done. Just refresh the button.
      updateBacklog(p.root);
      p.card.hidden = false;
    }

    // ── Takes Initiative cards ──────────────────────────────────────────
    // It Proposes - agent drafts outreach to the at-risk deals
    function runPropose(btn) {
      btn.classList.add('is-busy');
      btn.innerHTML = '<span class="bm-btn-spin"></span>Drafting…';
      var card = btn.closest('.bm-card');
      var q = card.querySelector('[data-propose-q]');
      if (q) q.hidden = true;

      var drafts = card.querySelectorAll('[data-draft]');
      var DRAFT_STEP = 1350;     // time between emails
      var DRAFT_RESOLVE = 1080;  // green liquid fills the loader, then "Drafted"

      for (var i = 0; i < drafts.length; i++) {
        (function (chip, idx) {
          setTimeout(function () { fillChip(chip, DRAFT_RESOLVE, 'Drafted'); }, idx * DRAFT_STEP);
        })(drafts[i], i);
      }

      // once all three are prepared → stream a confirmation that the drafts
      // landed in the user's own system (Outlook)
      setTimeout(function () {
        markDone(btn, 'Drafted ✓');
        var root = card.closest('[data-brief-stream]') || card.parentNode;
        var doneMsg = root.querySelector('[data-propose-done]');
        if (doneMsg) {
          doneMsg.hidden = false;
          var bubble = doneMsg.querySelector('[data-propose-done-text]');
          if (bubble) streamBubble(bubble, 'Drafts ready in your Outlook ✓');
        }
        scrollHint(btn.closest('.bm-actions') || btn.parentNode);
      }, (drafts.length - 1) * DRAFT_STEP + DRAFT_RESOLVE + 300);
    }

    // It Executes - send the drafted follow-up
    function runSendFollowup(btn) {
      btn.classList.add('is-busy');
      btn.innerHTML = '<span class="bm-btn-spin"></span>Sending…';
      var card = btn.closest('.bm-card');
      var status = card.querySelector('[data-exec-status]');
      var editBtn = card.querySelector('[data-action="execute-edit"]');
      setTimeout(function () {
        if (status) { status.textContent = 'Sent'; status.classList.remove('bm-chip-amber'); status.classList.add('bm-chip-teal'); }
        if (editBtn) editBtn.hidden = true;
        markDone(btn, 'Sent ✓');
        // confirmation now lives under the card and streams in like a message
        var root = card.closest('[data-brief-stream]') || card.parentNode;
        var confirm = root.querySelector('[data-exec-confirm]');
        if (confirm) {
          confirm.hidden = false;
          var bubble = confirm.querySelector('[data-exec-confirm-text]');
          if (bubble) streamBubble(bubble, '✓ Sent to Sarah. CRM updated with the thread.');
        }
        scrollHint(confirm);
      }, 1100);
    }

    // It Automates - flip the rule on
    function runAutomate(btn) {
      if (btn.classList.contains('on')) return;
      btn.classList.add('on');
      var card = btn.closest('.bm-card');
      var status = card.querySelector('[data-auto-status]');
      if (status) { status.textContent = 'On'; status.classList.remove('bm-chip-indigo'); status.classList.add('bm-chip-teal'); }
      // confirmation now lives under the card and streams in like a message
      var root = card.closest('[data-brief-stream]') || card.parentNode;
      var confirm = root.querySelector('[data-auto-confirm]');
      if (confirm) {
        confirm.hidden = false;
        var bubble = confirm.querySelector('[data-auto-confirm-text]');
        if (bubble) streamBubble(bubble, '✓ Automation on. I\'ll handle it from now on.');
      }
      scrollHint(card);
    }

    // ── You Stay In Control cards ───────────────────────────────────────
    // You Decide - approve / hold, two outcomes
    function runApprove(btn, approved) {
      var card = btn.closest('.bm-card');
      var actions = card.querySelector('[data-approve-actions]');
      var status = card.querySelector('[data-approve-status]');
      // confirmation now lives under the card and streams in like a message
      var root = card.closest('[data-brief-stream]') || card.parentNode;
      var confirm = root.querySelector('[data-approve-confirm]');
      var text = confirm ? confirm.querySelector('[data-approve-text]') : null;
      if (actions) actions.hidden = true;
      var msg;
      if (approved) {
        if (status) { status.textContent = 'Approved'; status.classList.remove('bm-chip-purple'); status.classList.add('bm-chip-teal'); }
        msg = '✓ On it, reaching out to all 47 leads now.';
      } else {
        if (status) { status.textContent = 'On hold'; }
        msg = "Holding. I won't reach out until you say so.";
      }
      if (confirm) {
        confirm.hidden = false;
        if (text) streamBubble(text, msg);
      }
      scrollHint(confirm);
    }

    // You Set the Rules - segmented control per action
    function runRuleOpt(btn) {
      var seg = btn.closest('[data-seg]');
      if (!seg) return;
      var opts = seg.querySelectorAll('[data-action="rule-opt"]');
      for (var i = 0; i < opts.length; i++) opts[i].classList.toggle('is-active', opts[i] === btn);
      var foot = btn.closest('.bm-card').querySelector('[data-rule-foot]');
      if (foot && foot.hidden) { foot.hidden = false; scrollHint(foot); }
    }

    // You have full oversight - reveal the activity log
    function runOversight(btn) {
      var card = btn.closest('.bm-card');
      var log = card.querySelector('[data-activity]');
      if (!log) return;
      log.hidden = false;
      var lines = log.querySelectorAll('.bm-actline');
      for (var i = 0; i < lines.length; i++) {
        (function (line, idx) {
          line.style.opacity = '0';
          setTimeout(function () { line.style.opacity = ''; line.classList.add('is-in'); }, idx * 160);
        })(lines[i], i);
      }
      markDone(btn, 'Live · 9 automations active');
      scrollHint(btn.closest('.bm-actions') || btn.parentNode);
    }
  })();

  // Typewriter for imagine section
  const introEl = document.getElementById('imagine-intro');
  const imagineLines = document.querySelectorAll('#imagine-lines .imagine-line-hidden');
  const plainText = 'Imagine you do nothing but your...';
  const finalHTML = 'Imagine you do nothing but your...';

  function revealLines() {
    imagineLines.forEach((line, i) => {
      setTimeout(() => {
        line.style.opacity = '1';
        line.style.transform = 'translateY(0) scale(1)';
        // dim the previous line now that the next one has arrived
        if (i > 0) imagineLines[i - 1].classList.add('is-dim');
      }, i * 715);
    });
    // after the same interval, dim the final line too
    const last = imagineLines.length - 1;
    if (last >= 0) {
      setTimeout(() => imagineLines[last].classList.add('is-dim'), imagineLines.length * 715);
    }
  }

  function runTypewriter() {
    let i = 0;
    const cursor = '<span class="tw-cursor">|</span>';
    const interval = setInterval(() => {
      i++;
      introEl.innerHTML = plainText.slice(0, i) + cursor;
      if (i === plainText.length) {
        clearInterval(interval);
        introEl.innerHTML = finalHTML;
        setTimeout(() => {
          introEl.classList.add('is-gone');
          revealLines();
        }, 250);
      }
    }, 98);
  }

  const imagineSection = document.getElementById('imagine');
  let twStarted = false;
  const twObserver = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting && !twStarted) {
      twStarted = true;
      twObserver.disconnect();
      setTimeout(runTypewriter, 260);
    }
  }, { threshold: 0.3 });
  if (imagineSection) twObserver.observe(imagineSection);

  // Focus email input helper
  function focusEmailInput() {
    const input = document.querySelector('.early-input');
    if (!input) return;
    const ctaSection = document.getElementById('cta');
    ctaSection?.scrollIntoView({ behavior: 'smooth' });
    setTimeout(() => input.focus(), 500);
  }

  document.getElementById('join-waitlist-btn')?.addEventListener('click', focusEmailInput);
  document.querySelector('.btn-cta')?.addEventListener('click', (e) => {
    e.preventDefault();
    focusEmailInput();
  });
</script>

<script define:vars={{ supabaseUrl: import.meta.env.PUBLIC_SUPABASE_URL, supabaseKey: import.meta.env.PUBLIC_SUPABASE_ANON_KEY }}>
  async function submitEmail(email) {
    if (!supabaseUrl || !supabaseKey) {
      console.error('[waitlist] Supabase config missing - check PUBLIC_SUPABASE_URL / PUBLIC_SUPABASE_ANON_KEY at build time.');
      return false;
    }
    const controller = new AbortController();
    const timeout = setTimeout(() => controller.abort(), 15000);
    try {
      const res = await fetch(`${supabaseUrl}/rest/v1/waitlist`, {
        method: 'POST',
        headers: {
          'apikey': supabaseKey,
          'Authorization': `Bearer ${supabaseKey}`,
          'Content-Type': 'application/json',
          'Prefer': 'return=minimal',
        },
        body: JSON.stringify({ email }),
        signal: controller.signal,
      });
      if (res.ok || res.status === 201 || res.status === 409) return true;
      const body = await res.text().catch(() => '');
      console.error(`[waitlist] insert failed: ${res.status} ${res.statusText}`, body);
      return false;
    } catch (err) {
      console.error('[waitlist] request failed (network/blocked/timeout):', err);
      return false;
    } finally {
      clearTimeout(timeout);
    }
  }

  const CHECK_SVG = `<svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52"><circle class="checkmark__circle" cx="26" cy="26" r="25" fill="none"/><path class="checkmark__check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/></svg>`;

  function wireForm(formId, successId) {
    const form = document.getElementById(formId);
    const success = document.getElementById(successId);
    if (!form) return;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[type="email"]');
      const btn = form.querySelector('button');
      const email = input.value.trim();
      if (!email) { input.focus(); return; }
      btn.disabled = true;
      btn.textContent = 'Saving...';
      const ok = await submitEmail(email);
      if (ok) {
        input.style.transition = 'opacity 0.3s, width 0.35s, padding 0.35s, margin 0.35s';
        input.style.opacity = '0';
        input.style.width = '0';
        input.style.padding = '0';
        input.style.margin = '0';
        btn.innerHTML = CHECK_SVG;
        btn.classList.add('is-success');
        if (success) {
          setTimeout(() => { success.hidden = false; }, 400);
        }
      } else {
        btn.disabled = false;
        btn.textContent = 'Try again';
      }
    });
  }

  wireForm('form-hero', 'success-hero');
  wireForm('form-cta', 'success-cta');
</script>

<style is:global>
  .checkmark {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: block;
    stroke-width: 2;
    stroke: #fff;
    stroke-miterlimit: 10;
    box-shadow: inset 0px 0px 0px #22c55e;
    animation: checkmark-fill 0.4s ease-in-out 0.4s forwards, checkmark-scale 0.3s ease-in-out 0.9s both;
  }
  .checkmark__circle {
    stroke-dasharray: 166;
    stroke-dashoffset: 166;
    stroke-width: 2;
    stroke-miterlimit: 10;
    stroke: #22c55e;
    fill: none;
    animation: checkmark-stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
  }
  .checkmark__check {
    transform-origin: 50% 50%;
    stroke-dasharray: 48;
    stroke-dashoffset: 48;
    animation: checkmark-stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards;
  }
  @keyframes checkmark-stroke {
    100% { stroke-dashoffset: 0; }
  }
  @keyframes checkmark-scale {
    0%, 100% { transform: none; }
    50% { transform: scale3d(1.1, 1.1, 1); }
  }
  @keyframes checkmark-fill {
    100% { box-shadow: inset 0px 0px 0px 30px #22c55e; }
  }
</style>
