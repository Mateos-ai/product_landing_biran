    content: ''; position: absolute; inset: -1px; border-radius: calc(var(--radius-sm) + 1px);
    padding: 1px; background: linear-gradient(90deg, var(--amber-500), var(--teal-500), var(--indigo-500), var(--amber-500));
    background-size: 300% 100%;
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out; mask-composite: exclude;
    animation: btn-glow-move 2s linear infinite; z-index: -1;
