  .cc-label-outer { top: -2px; color: var(--amber-600); }
  :global([data-theme="dark"]) .cc-label-outer { color: var(--amber-400); }
  .cc-label-mid { top: 12%; color: var(--text-secondary); font-size: 0.58rem; }
  .cc-node { position: absolute; width: 9px; height: 9px; border-radius: 50%; }
  .cc-node-1 { top: 6%; right: 20%; background: var(--amber-500); box-shadow: 0 0 0 4px var(--color-primary-soft); }
  .cc-node-2 { bottom: 14%; left: 8%; background: var(--teal-500); box-shadow: 0 0 0 4px var(--color-accent-soft); }
  .cc-node-3 { bottom: 8%; right: 12%; background: var(--indigo-500); box-shadow: 0 0 0 4px var(--color-secondary-soft); }

  /* ── Principles ──────────────────────────────────────────────────────── */
