  .thesis-sub {
    font-family: var(--font-body); font-size: clamp(1rem, 2vw, 1.2rem); font-weight: 400;
    line-height: 1.7; color: rgba(255,255,255,0.6); margin-top: 44px; max-width: 620px; margin-inline: auto;
  }
  .tw-cursor { display: inline-block; color: var(--amber-500); animation: tw-blink 0.7s steps(1) infinite; font-weight: 300; }
