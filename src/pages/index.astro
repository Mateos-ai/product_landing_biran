  .btn-cta {
    display: inline-block; background: var(--color-primary); color: var(--on-primary);
    font-weight: 600; font-size: 0.875rem; padding: 0.5rem 1.1rem;
    border-radius: var(--radius-sm); transition: background 0.2s, transform 0.15s; white-space: nowrap;
  }
  .btn-cta:hover { background: var(--color-primary-hover); transform: translateY(-1px); }

  /* offset anchored sections so the sticky header never covers their titles */
  section[id] { scroll-margin-top: 84px; }

  /* ── Shared section header ───────────────────────────────────────────── */
  .section-header { text-align: center; margin-bottom: 56px; max-width: 760px; margin-inline: auto; }
  .section-header h2 { font-size: clamp(2rem, 4.5vw, 3.25rem); margin-bottom: 14px; }
  .section-sub { color: var(--text-secondary); font-size: 1.05rem; max-width: 620px; margin: 0 auto; line-height: 1.7; }
  .gradient-text {
    background: var(--gradient-brand); -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  em { font-style: normal; color: var(--text-primary); font-weight: 600; }

  /* ── Hero ────────────────────────────────────────────────────────────── */
  .hero {
    position: relative; overflow: hidden; background: var(--hero-bg);
    min-height: 92vh; min-height: 92svh; display: flex; align-items: center; text-align: center;
  }
  .grid-bg {
    position: absolute; inset: 0; pointer-events: none;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 56px 56px;
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 0%, transparent 78%);
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, #000 0%, transparent 78%);
    opacity: 0.5;
  }
  .hero-inner { position: relative; z-index: 1; display: flex; flex-direction: column; align-items: center; gap: 22px; }
  .hero-logo { height: 64px; width: auto; margin-bottom: 4px; }
  .hero h1 {
    font-size: clamp(2.5rem, 6.5vw, 5rem); color: var(--hero-heading);
    line-height: 1.04; letter-spacing: -0.03em; max-width: 15ch;
  }
  .hero-tagline {
    font-size: clamp(1.05rem, 2vw, 1.3rem); font-weight: 400; color: var(--hero-body);
    line-height: 1.6; max-width: 640px;
  }
  .hero-actions { display: flex; gap: 14px; flex-wrap: wrap; align-items: center; justify-content: center; margin-top: 10px; }

  /* Buttons */
  .btn-primary-lg {
    display: inline-block; background: var(--color-primary); color: var(--on-primary);
    font-weight: 700; font-size: 0.98rem; padding: 0.8rem 1.7rem; border-radius: var(--radius-sm);
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s; box-shadow: var(--shadow-md);
  }
