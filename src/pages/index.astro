  }

  /* Concentric-circles motif */
  .cc-wrap { position: relative; width: 100%; max-width: 420px; margin-inline: auto; aspect-ratio: 1; }
  .cc { border-radius: 50%; display: flex; align-items: center; justify-content: center; position: relative; }
  .cc-outer {
    width: 100%; height: 100%;
    background: conic-gradient(from 180deg, var(--amber-500), var(--teal-500), var(--indigo-500), var(--amber-500));
    padding: 3px;
  }
  .cc-outer::before { content: ""; position: absolute; inset: 3px; border-radius: 50%; background: var(--surface-subtle); }
  .cc-mid { width: 74%; height: 74%; z-index: 1; border: 1.5px dashed var(--border-strong); background: var(--surface); }
  .cc-core {
    width: 62%; height: 62%; flex-direction: column; gap: 6px; text-align: center;
    background: var(--surface-inverse); color: var(--text-inverse); box-shadow: var(--shadow-lg);
