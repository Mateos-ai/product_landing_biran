        <a href={`tel:${contact.phone.replace(/\s/g, "")}`}><span set:html={ICON.phone} />{contact.phone}</a>
        <a href={contact.linkedin} target="_blank" rel="noopener"><span set:html={ICON.linkedin} />LinkedIn</a>
