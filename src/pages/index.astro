  .sec-teal {
    --sec: var(--teal-500);
    --sec-strong: var(--teal-600);
    --sec-soft: var(--color-accent-soft);
    --sec-text: var(--teal-700);
    --sec-text-dk: var(--teal-200);
    --sec-icon: var(--teal-600);
    --sec-icon-dk: var(--teal-400);
    --sec-border: var(--teal-400);
    --sec-on: var(--on-accent);
    --sec-hint: 23, 190, 187;
  }
  .sec-purple {
    --sec: var(--indigo-500);
    --sec-strong: var(--indigo-600);
    --sec-soft: var(--color-secondary-soft);
    --sec-text: var(--indigo-600);
    --sec-text-dk: var(--indigo-200);
    --sec-icon: var(--indigo-600);
    --sec-icon-dk: var(--indigo-400);
    --sec-border: var(--indigo-300);
    --sec-on: #fff;
    --sec-hint: 91, 83, 232;
  }

  /* Sales Magician: same palette, but assigned per step (orange → teal → purple) */
  .sec-steps .step-amber {
    --sec: var(--amber-500); --sec-strong: var(--amber-600); --sec-soft: var(--color-primary-soft);
    --sec-text: var(--amber-700); --sec-text-dk: var(--amber-200);
    --sec-icon: var(--amber-600); --sec-icon-dk: var(--amber-400);
    --sec-border: var(--amber-400); --sec-on: var(--on-primary); --sec-hint: 255, 140, 66;
  }
  .sec-steps .step-teal {
    --sec: var(--teal-500); --sec-strong: var(--teal-600); --sec-soft: var(--color-accent-soft);
    --sec-text: var(--teal-700); --sec-text-dk: var(--teal-200);
    --sec-icon: var(--teal-600); --sec-icon-dk: var(--teal-400);
    --sec-border: var(--teal-400); --sec-on: var(--on-accent); --sec-hint: 23, 190, 187;
  }
  .sec-steps .step-indigo {
    --sec: var(--indigo-500); --sec-strong: var(--indigo-600); --sec-soft: var(--color-secondary-soft);
    --sec-text: var(--indigo-600); --sec-text-dk: var(--indigo-200);
    --sec-icon: var(--indigo-600); --sec-icon-dk: var(--indigo-400);
    --sec-border: var(--indigo-300); --sec-on: #fff; --sec-hint: 91, 83, 232;
  }

  /* title accent ("It", "You", …) */
  .sec-mono .brand-text,
  .sec-mono .brand-text-purple { color: var(--sec); }

  /* step icon + connector line */
  .sec-mono .step-icon { border-color: var(--sec-border); background: var(--sec-soft); color: var(--sec-icon); }
  :global([data-theme="dark"]) .sec-mono .step-icon { color: var(--sec-icon-dk); }
  .sec-mono:not(.sec-steps) .pin-panel .step-icon::before { background: var(--sec); }

  /* avatars */
  .sec-mono .bm-avatar,
  .sec-mono .bm-avatar-teal,
  .sec-mono .bm-avatar-indigo { background: var(--sec); color: var(--sec-on); }

  /* chips + status badges */
  .sec-mono .bm-chip-amber,
  .sec-mono .bm-chip-teal,
  .sec-mono .bm-chip-indigo,
  .sec-mono .bm-chip-purple { background: var(--sec-soft); color: var(--sec-text); }
  :global([data-theme="dark"]) .sec-mono .bm-chip-amber,
  :global([data-theme="dark"]) .sec-mono .bm-chip-teal,
  :global([data-theme="dark"]) .sec-mono .bm-chip-indigo,
  :global([data-theme="dark"]) .sec-mono .bm-chip-purple { color: var(--sec-text-dk); }

  /* confirmation bubbles */
  .sec-mono .bm-bubble-teal,
  .sec-mono .bm-bubble-indigo { border-color: var(--sec-border); background: var(--sec-soft); color: var(--sec-text); }
  :global([data-theme="dark"]) .sec-mono .bm-bubble-teal,
  :global([data-theme="dark"]) .sec-mono .bm-bubble-indigo { color: var(--sec-text-dk); }

  /* tags */
  .sec-mono .tag-amber,
  .sec-mono .tag-teal,
  .sec-mono .tag-indigo { background: var(--sec-soft); color: var(--sec-text); }
  :global([data-theme="dark"]) .sec-mono .tag-amber,
  :global([data-theme="dark"]) .sec-mono .tag-teal,
  :global([data-theme="dark"]) .sec-mono .tag-indigo { color: var(--sec-text-dk); }

  /* buttons */
  .sec-mono .bm-btn-primary { background: var(--sec); border-color: var(--sec); color: var(--sec-on); }
  .sec-mono .bm-btn-done { color: var(--sec-text); }
  :global([data-theme="dark"]) .sec-mono .bm-btn-done { color: var(--sec-text-dk); }

  /* toggle switch, segmented control, checkboxes */
  .sec-mono .bm-switch.on { background: var(--sec); }
  .sec-mono .bm-seg-opt.is-active { background: var(--sec); color: var(--sec-on); }
  .sec-mono .bm-checkbox:checked + .bm-task-box,
  .sec-mono .bm-task.is-done .bm-task-box { background: var(--sec); border-color: var(--sec); }
  .sec-mono .bm-checkbox:focus-visible + .bm-task-box { outline-color: var(--sec); }

  /* approval card border + saved footnote */
  .sec-mono .bm-card-approve { border-color: var(--sec-border); }
  .sec-mono .bm-card-foot { color: var(--sec-text); }
  :global([data-theme="dark"]) .sec-mono .bm-card-foot { color: var(--sec-text-dk); }

  /* interactive-hint glow */
  .sec-mono .pin-panel { --hint: var(--sec-hint); }

  /* runtime-created CRM sync loader bar (lives outside Astro scoping) */
  .sec-mono :global(.bm-chip-bar-fill) { background: linear-gradient(90deg, var(--sec-strong), var(--sec)); }
