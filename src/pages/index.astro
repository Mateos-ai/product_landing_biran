---
import Layout from "@/layouts/Layout.astro";
import DemoVideo from "@/components/DemoVideo.astro";

// ── Icons (Feather-style, inherit currentColor) ────────────────────────────
const s = (p: string) =>
  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">${p}</svg>`;
const ICON = {
  compass: s(`<circle cx="12" cy="12" r="10"/><polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76"/>`),
  target: s(`<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>`),
  layers: s(`<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>`),
  brain: s(`<circle cx="12" cy="12" r="3"/><circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="18" r="2"/><line x1="7" y1="6.7" x2="9.6" y2="10.6"/><line x1="17" y1="6.7" x2="14.4" y2="10.6"/><line x1="7" y1="17.3" x2="9.6" y2="13.4"/><line x1="17" y1="17.3" x2="14.4" y2="13.4"/>`),
  users: s(`<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>`),
  cap: s(`<path d="M22 10L12 5 2 10l10 5 10-5z"/><path d="M6 12v5c0 1 2.5 3 6 3s6-2 6-3v-5"/>`),
  crosshair: s(`<circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/>`),
  package: s(`<path d="M16.5 9.4 7.5 4.21"/><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>`),
  refresh: s(`<polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>`),
  shield: s(`<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>`),
  cpu: s(`<rect x="4" y="4" width="16" height="16" rx="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>`),
  briefcase: s(`<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`),
  spark: s(`<path d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5 18 18M18 6l-2.5 2.5M8.5 15.5 6 18"/>`),
  mail: s(`<rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/>`),
  phone: s(`<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/>`),
  linkedin: s(`<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-11h4v1.5a4 4 0 0 1 6 2.5"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>`),
  whatsapp: `<svg width="22" height="22" viewBox="0 0 778.72 778.72" fill="currentColor"><path d="M524.354 440.616c-6.936-3.47-41.036-20.245-47.395-22.558-6.357-2.314-10.98-3.471-15.604 3.47-4.624 6.942-17.916 22.559-21.963 27.187-4.045 4.627-8.09 5.207-15.026 1.735-6.936-3.47-29.284-10.792-55.776-34.415-20.62-18.384-34.54-41.092-38.586-48.033-4.045-6.942-.43-10.694 3.043-14.151 3.119-3.105 6.935-8.097 10.403-12.147 3.468-4.05 4.624-6.941 6.936-11.568 2.312-4.628 1.156-8.677-.58-12.148-1.732-3.47-15.603-37.598-21.383-51.481-5.63-13.52-11.348-11.69-15.605-11.903-4.042-.201-8.67-.244-13.294-.244-4.624 0-12.137 1.736-18.496 8.676-6.357 6.942-24.274 23.718-24.274 57.844 0 34.128 24.853 67.099 28.32 71.727 3.469 4.628 48.909 74.663 118.485 104.696 16.548 7.144 29.468 11.41 39.54 14.607 16.616 5.276 31.736 4.532 43.687 2.746 13.325-1.99 41.036-16.774 46.816-32.97 5.778-16.196 5.778-30.08 4.045-32.971-1.733-2.892-6.357-4.628-13.293-8.099M397.8 613.355h-.093c-41.4-.016-82.005-11.133-117.428-32.148l-8.425-5-87.322 22.9 23.308-85.11-5.486-8.726c-23.095-36.723-35.292-79.167-35.275-122.747.05-127.168 103.55-230.628 230.813-230.628 61.624.024 119.552 24.047 163.112 67.642 43.56 43.596 67.536 101.545 67.512 163.173-.052 127.177-103.55 230.644-230.716 230.644M594.158 186.41c-52.408-52.452-122.104-81.352-196.36-81.381-153 0-277.524 124.476-277.586 277.477-.02 48.908 12.762 96.65 37.052 138.73l-39.38 143.797 147.152-38.587c40.544 22.107 86.192 33.756 132.65 33.776h.116c152.985 0 277.52-124.492 277.582-277.495.028-74.146-28.817-143.866-81.226-196.317" fill-rule="evenodd"/></svg>`,
  trendingUp: s(`<polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/>`),
  checkCircle: s(`<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`),
  cycle3: s(`<g stroke="var(--amber-500)" fill="var(--amber-500)"><path d="M12 4 Q18 4 18 9" fill="none"/><polygon points="15.5 8 20.5 8 18 11.5"/></g><g stroke="var(--teal-500)" fill="var(--teal-500)" transform="rotate(120 12 12)"><path d="M12 4 Q18 4 18 9" fill="none"/><polygon points="15.5 8 20.5 8 18 11.5"/></g><g stroke="var(--indigo-500)" fill="var(--indigo-500)" transform="rotate(240 12 12)"><path d="M12 4 Q18 4 18 9" fill="none"/><polygon points="15.5 8 20.5 8 18 11.5"/></g>`),
};

// ── What We Do: the journey (four steps) ──────────────────────────────────
const journey = [
  { n: "01", icon: ICON.compass, title: "Diagnose Deep", sub: "We map your organization, your data and your workflows, and pinpoint where AI pays back first, in any department.", color: "amber" },
  { n: "02", icon: ICON.checkCircle, title: "Prove", sub: "A focused solution at your sharpest pain point, measured against agreed results in weeks, not promises.", color: "teal" },
  { n: "03", icon: ICON.cycle3, title: "Replicate", sub: "Agents and automations roll out department by department, building toward one orchestrating Company Brain.", color: "gradient" },
];

// ── Ways to work with us (secondary row) ────────────────────────────────────
const ways = [
  { icon: ICON.briefcase, title: "Fractional CAIO", sub: "A senior Chief AI Officer embedded in your leadership, driving the platform and the roadmap, part-time.", color: "amber" },
  { icon: ICON.cap, title: "Workshops", sub: "Hands-on sessions that get your people building with our agents, fast.", color: "teal" },
  { icon: ICON.package, title: "Projects", sub: "A defined build on our platform, with a clear scope, owned end to end.", color: "indigo" },
];

// ── The platform: software, not just people ─────────────────────────────────
const platform = [
  { icon: ICON.cpu, title: "Agents", color: "amber", sub: "Purpose-built AI agents wired into the tools you already run on." },
  { icon: ICON.trendingUp, title: "Learning", color: "teal", sub: "Every agent is evaluated and improves with every run." },
  { icon: ICON.layers, title: "Data Analysis", color: "indigo", sub: "Your operational data, turned into the signals that make agents useful." },
  { icon: ICON.target, title: "Company Brain", color: "gradient", sub: "An Orchestrating Layer: What one team learns, the whole company knows." },
];

// ── The adoption layer ──────────────────────────────────────────────────────
const adoption = [
  { icon: ICON.spark, title: "A structured adoption program", sub: "Built around how your people actually work, not a generic rollout." },
  { icon: ICON.cap, title: "Training on the systems we build", sub: "Your teams learn the exact tools we deploy for you, hands-on." },
  { icon: ICON.users, title: "Champions inside your organization", sub: "We grow internal owners who carry the change forward." },
];

// ── How we work: principles ────────────────────────────────────────────────
const principles = [
  { icon: ICON.crosshair, title: "Start at the sharpest pain", body: `A bottleneck on the production line, a swamped service desk, a finance close that eats a week. We start where it hurts most, in any function.`, color: "amber" },
  { icon: ICON.layers, title: "Solve today, build for tomorrow", body: `Every solution ships value now <em>and</em> becomes a building block toward the Company Brain. Nothing is throwaway.`, color: "teal" },
  { icon: ICON.package, title: "Own it end to end", body: `Diagnosis, solution, implementation, training. Real work on the ground, not slide decks and hand-offs.`, color: "indigo" },
  { icon: ICON.refresh, title: "Every project compounds", body: `What we build for one team becomes knowledge the whole organization can reuse. The value accumulates.`, color: "amber" },
];

// ── The team ────────────────────────────────────────────────────────────────
const team = [
  { name: "Yair Nativ", role: "Founder & CEO", initials: "YN", photo: "/yair-nativ.png", bio: "A 3x, award-winning entrepreneur across tech and social impact, with a track record of founding AI and productivity ventures.", li: "https://www.linkedin.com/in/yairnativ/", color: "amber" },
  { name: "David L. Rajcher", role: "Founder & CTO", initials: "DR", photo: "/david-rajcher.png", bio: "Engineer and 2x tech founder, ex-IDF technologist with two decades building and leading engineering teams from the ground up.", li: "https://www.linkedin.com/in/david-rajcher/", color: "teal" },
  { name: "Aviv Yogev", role: "Founder & COO", initials: "AY", color: "indigo" },
  { name: "Noam Biran", role: "Head of Partnerships", initials: "NB", photo: "/noam-biran.jpeg", bio: "Former industrialist and founder of BIRANO, a B2B and B2B2C branding and marketing studio. Board member of the Manufacturers Association of Israel and a member of the Chamber of Commerce.", li: "https://www.linkedin.com/in/birannoam/", color: "amber" },
  { name: "Noam Mantel", role: "Head of Product", initials: "NM", photo: "/noam-mantel.jpeg", bio: "Ex-VP of Product at Slack, with product leadership at AB InBev. 15+ years shipping complex B2B and B2C products at scale.", li: "https://www.linkedin.com/in/noammantel/", color: "teal" },
  { name: "Shayna Moliver", role: "Chief of Staff", initials: "SM", photo: "/shayna-moliver.jpeg", bio: "Chief of Staff for hire across startups, growth-stage companies and boutique consulting firms in Israel and the US. Board member of the National Giving Alliance and the Park Slope Food Coop.", li: "https://www.linkedin.com/in/shaynamoliver/", color: "indigo" },
];

// Academic advisors (real experts; bios drawn from public sources).
const advisors = [
  {
    name: "Prof. Michael Schrage",
    role: "AI KPIs Advisor",
    initials: "MS",
    photo: "/michael-schrage.webp",
    bio: "Research fellow at MIT Sloan's Initiative on the Digital Economy. His research on AI-enhanced KPIs reframes metrics as sources of strategic value, not merely measures of it.",
    li: "https://www.linkedin.com/in/mschrage/",
    color: "indigo",
  },
  {
    name: "Prof. Nir Eisikovits",
    role: "AI Ethics Advisor",
    initials: "NE",
    photo: "/nir-eisikovits.webp",
    bio: "Professor of philosophy and founding director of the Applied Ethics Center at UMass Boston. His recent work focuses on the ethics of AI and how working with it reshapes how we understand ourselves.",
    li: "https://www.linkedin.com/in/nir-eisikovits-8781018/",
    color: "amber",
  },
];

// ── Example solutions (pre-recorded, self-playing demos) ────────────────────
const opWizardDemos = [
  { name: "workflow-0", eyebrow: "Morning", title: "It plans your day", sub: "Meetings, priorities and prep for every call, ready before you are.", color: "amber" },
  { name: "workflow-1", eyebrow: "After a meeting", title: "It keeps records current", sub: "Say what happened and the system updates itself: stage, next steps, notes. No forms.", color: "teal" },
  { name: "workflow-2", eyebrow: "End of day", title: "It clears the busywork", sub: "Drafts sent, records updated, schedules fixed, so tomorrow starts clean.", color: "indigo" },
];
const salesDemos = [
  { name: "magician-0", eyebrow: "Top of funnel", title: "Fills the pipeline", sub: "Fresh leads, new angles to sell, and untapped markets to go after.", color: "amber" },
  { name: "magician-1", eyebrow: "Before an event", title: "Wins the event", sub: "Matches attendees to your ideal profile, drafts intros, and books the meetings.", color: "teal" },
  { name: "magician-2", eyebrow: "Existing accounts", title: "Grows the relationship", sub: "Spots expansion signals: upsell moments, likely renewals, warm intros in your network.", color: "indigo" },
];

// ── Integrations (runs on the tools you already use) ────────────────────────
const integrations = [
  { name: "WhatsApp", src: "/whatsapp.svg" },
  { name: "HubSpot", src: "/hubspot.webp" },
  { name: "Notion", src: "/notion.webp" },
  { name: "Zendesk", src: "/zendesk.webp" },
  { name: "Salesforce", src: "/salesforce.webp" },
  { name: "Monday", src: "/monday.webp" },
  { name: "ClickUp", src: "/clickup.webp" },
  { name: "Todoist", src: "/todoist.webp" },
  { name: "Gmail", src: "/gmail.webp" },
  { name: "Google Calendar", src: "/gcalendar.webp" },
  { name: "Outlook", src: "/outlook.webp" },
];

// ── Contact (placeholders, replace with real details) ──────────────────────
const contact = {
  email: "hello@mateos.ai",
  phone: "+972 50 555 9748",
  linkedin: "https://www.linkedin.com/company/mateos-ai",
  whatsapp: "https://wa.me/972505559748",
};
---

<Layout>
  <!-- ── NAVBAR ──────────────────────────────────────────────────────── -->
  <header>
    <div class="wrap bar">
      <a href="#top" class="brand" aria-label="Mateos.ai home">
        <img src="/mateos-logo.svg" alt="" class="brand-mark" />
        <span class="brand-name">mateos<span class="brand-ai">.ai</span></span>
      </a>

      <nav class="nav-links" aria-label="Sections">
        <a href="#approach">Approach</a>
        <a href="#platform">Platform</a>
        <a href="#adoption">Adoption</a>
        <a href="#how">How we work</a>
        <a href="#team">Team</a>
        <a href="#examples">Examples</a>
        <a href="#integrations">Integrations</a>
      </nav>

      <div class="nav-right">
        <a href="#pilot" class="btn-cta">Start a Pilot</a>
        <div class="theme-picker" id="theme-picker">
          <button class="theme-trigger" id="theme-trigger" aria-haspopup="listbox" aria-expanded="false" aria-label="Color theme">
            <span class="theme-icon" id="theme-icon"></span>
          </button>
          <ul class="theme-dropdown" role="listbox" id="theme-dropdown">
            <li class="theme-opt" role="option" data-value="system">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              System
            </li>
            <li class="theme-opt" role="option" data-value="light">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
              Light
            </li>
            <li class="theme-opt" role="option" data-value="dark">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
              Dark
            </li>
          </ul>
        </div>
      </div>
    </div>
  </header>

  <main id="top">
    <!-- ── HERO ───────────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="grid-bg" aria-hidden="true"></div>
      <div class="wrap hero-inner">
        <img src="/mateos-logo-secondary.svg" alt="" class="hero-logo" />
        <h1>
          From Complexity to Efficiency:<br />
          <span class="gradient-text">AI Automation Built for Industrial Growth.</span>
        </h1>
        <p class="hero-tagline">
          We build the software, deploy it inside your organization, and take ownership
          of the result. Then we train your people to run it.
        </p>
        <div class="hero-kpi">
          <span class="hero-kpi-dot" aria-hidden="true"></span>
          25% of our fee is tied to your KPIs.
        </div>
        <div class="hero-actions">
          <a href="#approach" class="btn-ghost-lg">See how it works ↓</a>
        </div>
      </div>
    </section>

    <!-- ── WHAT WE DO: THE JOURNEY ───────────────────────────────────── -->
    <section class="approach-section" id="approach">
      <div class="wrap">
        <div class="section-header" data-reveal>
          <div class="eyebrow">What we do</div>
          <h2>Not Just Automation.<br /><span class="gradient-text">A Company Brain.</span></h2>
          <p class="section-sub">A step-by-step journey, wrapped at every step by the change layer that makes it stick.</p>
        </div>

        <div class="journey" data-reveal>
          <div class="journey-steps">
            {journey.map((step, i) => (
              <>
                <article class={`journey-step jstep-${step.color}`}>
                  <div class="journey-n">{step.n}</div>
                  <span class="journey-icon" set:html={step.icon} />
                  <h3>{step.title}</h3>
                  <p>{step.sub}</p>
                </article>
                {i < journey.length - 1 && <span class="journey-arrow" aria-hidden="true">→</span>}
              </>
            ))}
          </div>
        </div>

        <div class="ways">
          <div class="ways-head" data-reveal>
            <div class="eyebrow">Ways to work with us</div>
            <h3>Start where it fits your organization</h3>
          </div>
          <div class="ways-grid">
            {ways.map((w) => (
              <article class={`way-card way-${w.color}`} data-reveal>
                <span class="way-icon" set:html={w.icon} />
                <h4>{w.title}</h4>
                <p>{w.sub}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- ── THE PLATFORM: SOFTWARE, NOT JUST PEOPLE ───────────────────── -->
    <section class="platform-section" id="platform">
      <div class="wrap">
        <div class="section-header" data-reveal>
          <div class="eyebrow">The platform</div>
          <h2>Software, <span class="gradient-text">not just people</span></h2>
          <p class="section-sub">
            Most of what you'll see in this space is an agency: people, billed by the hour.
            This is the technology we own and keep building on your behalf.
          </p>
        </div>
        <div class="platform-grid">
          {platform.map((p, i) => (
            <>
              <article class={`platform-card pf-${p.color}`} data-reveal>
                <span class="platform-icon" set:html={p.icon} />
                <h3>{p.title}</h3>
                <p>{p.sub}</p>
              </article>
              {i < platform.length - 1 && (
                <span class={`platform-op${i === platform.length - 2 ? " platform-op-eq" : ""}`} aria-hidden="true">
                  {i === platform.length - 2 ? "=" : "+"}
                </span>
              )}
            </>
          ))}
        </div>
      </div>
    </section>

    <!-- ── THE ADOPTION LAYER ─────────────────────────────────────────── -->
    <section class="adoption-section" id="adoption">
      <div class="wrap adoption-grid">
        <div class="adoption-copy" data-reveal>
          <div class="eyebrow">The adoption layer</div>
          <h2>Technology is not enough, <span class="gradient-text">adoption is the missing piece.</span></h2>
          <p class="section-sub adoption-lead">
            Connecting the technology is the part everyone talks about. Getting hundreds of people
            to change how they work every day is the part that decides whether it lasts. It is the
            wrapper around everything we build.
          </p>
          <ul class="adoption-list">
            {adoption.map((a) => (
              <li>
                <span class="adopt-icon" set:html={a.icon} />
                <span>
                  <strong>{a.title}</strong>
                  <span class="adopt-sub">{a.sub}</span>
                </span>
              </li>
            ))}
          </ul>
          <p class="adoption-key">"We don't leave until your people run it without us."</p>
        </div>

        <!-- Concentric-circles motif: technology core, wrapped by the change layer -->
        <div class="cc-wrap" data-reveal aria-hidden="true">
          <div class="cc cc-outer">
            <span class="cc-ring-label cc-label-outer">Adoption &amp; Training</span>
            <div class="cc cc-mid">
              <span class="cc-ring-label cc-label-mid">Agents</span>
              <div class="cc cc-core">
                <span class="cc-core-text">Company<br />Brain</span>
              </div>
            </div>
          </div>
          <span class="cc-node cc-node-1"></span>
          <span class="cc-node cc-node-2"></span>
          <span class="cc-node cc-node-3"></span>
