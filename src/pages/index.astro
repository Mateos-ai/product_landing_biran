  .bm-line-title { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

  .bm-chip {
    font-family: var(--font-mono); font-size: 0.6rem; font-weight: 600;
    padding: 3px 8px; border-radius: var(--radius-full); white-space: nowrap;
    text-transform: uppercase; letter-spacing: 0.04em; flex-shrink: 0;
  }
  .bm-chip-amber { background: var(--color-primary-soft); color: var(--amber-700); }
  .bm-chip-teal  { background: var(--color-accent-soft);  color: var(--teal-700); }
  .bm-chip-indigo { background: var(--color-secondary-soft); color: var(--indigo-600); }
  .bm-chip-purple { background: var(--color-secondary-soft); color: var(--color-secondary); }
  :global([data-theme="dark"]) .bm-chip-amber { color: var(--amber-200); }
  :global([data-theme="dark"]) .bm-chip-teal  { color: var(--teal-200); }
  :global([data-theme="dark"]) .bm-chip-indigo,
  :global([data-theme="dark"]) .bm-chip-purple { color: var(--indigo-200); }

  .bm-actions { display: flex; gap: 8px; }
  .bm-btn {
    font-size: 0.76rem; font-weight: 600; padding: 6px 14px;
    border-radius: var(--radius-sm); border: 1px solid var(--border);
    color: var(--text-secondary); background: var(--surface);
  }
  .bm-btn-primary {
    background: var(--color-primary); border-color: var(--color-primary); color: var(--on-primary);
  }

  .bm-panel { display: flex; flex-direction: column; gap: 10px; }
  .bm-panel-label {
    font-family: var(--font-mono); font-size: 0.66rem; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--text-muted); margin-top: 6px;
  }
  .bm-rule {
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: 10px 12px;
  }
  .bm-rule-text { display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .bm-rule-title { font-size: 0.82rem; font-weight: 600; color: var(--text-primary); }
  .bm-rule-sub { font-size: 0.72rem; color: var(--text-muted); }
  .bm-switch {
    width: 34px; height: 20px; border-radius: var(--radius-full);
    background: var(--neutral-300); position: relative; flex-shrink: 0;
  }
  .bm-switch.on { background: var(--color-accent); }
  .bm-switch::after {
    content: ''; position: absolute; top: 2px; left: 2px;
    width: 16px; height: 16px; border-radius: var(--radius-full);
    background: #fff; box-shadow: var(--shadow-xs);
  }
  .bm-switch.on::after { left: 16px; }
  .bm-panel-foot {
    font-family: var(--font-mono); font-size: 0.68rem; color: var(--text-muted);
    text-align: center; margin-top: 4px;
  }

  /* ── Pinned, scroll-driven workflow section ──────────────────────────── */
  .pin-track { position: relative; }
  .pin-header { text-align: center; margin-bottom: 36px; position: relative; z-index: 2; }
  .pin-header h2 { font-size: clamp(2rem, 4.5vw, 3.25rem); }
  .pin-lead { margin-top: 12px; font-size: clamp(0.95rem, 1.6vw, 1.15rem); color: var(--text-muted); }
  .pin-dots { display: none; justify-content: center; gap: 8px; margin-top: 18px; }
  .pin-dot {
    width: 8px; height: 8px; border-radius: var(--radius-full);
    background: var(--border-strong); transition: width 0.3s, background 0.3s;
  }
  .pin-dot.is-active { width: 22px; background: var(--color-primary); }

  .pin-deck { position: relative; z-index: 1; }
  /* each card fills (about) a full viewport so only one demo shows at a time */
  .pin-panel {
    position: relative; z-index: 1;
    display: flex; flex-direction: column; gap: 24px; align-items: center;
    justify-content: center;
    min-height: 100vh; min-height: 100svh;
    padding: 48px 0;
  }
  .pin-meta { display: flex; gap: 20px; align-items: flex-start; width: 100%; max-width: 460px; }
  .pin-meta .step-icon { flex-shrink: 0; }
  .pin-meta-text h3 { font-size: 1.5rem; margin: 4px 0 10px; }
  .pin-sub {
    font-size: 0.95rem; line-height: 1.6; color: var(--text-secondary);
    max-width: 46ch; margin: 0;
  }
  .pin-visual { width: 100%; max-width: 460px; }

  .pin-window {
    position: relative;
    border-radius: var(--radius-lg); background: var(--surface);
    border: 1px solid var(--border); box-shadow: var(--shadow-xl); overflow: hidden;
  }
  /* .demo-cursor is created at runtime, so it's styled in global.css (unscoped) */
  .pin-window-chrome {
    display: flex; align-items: center; gap: 8px;
    padding: 11px 14px; background: var(--surface-muted); border-bottom: 1px solid var(--border);
  }
  .pin-window-chrome .dot { width: 11px; height: 11px; border-radius: var(--radius-full); flex-shrink: 0; }
  .pin-window-chrome .dot-red { background: #FF5F57; }
  .pin-window-chrome .dot-amber { background: #FEBC2E; }
  .pin-window-chrome .dot-green { background: #28C840; }
  .pin-window-url {
    flex: 1; text-align: center; font-family: var(--font-mono);
    font-size: 0.72rem; color: var(--text-muted);
  }
  .pin-window-body { padding: 18px; background: var(--surface-subtle); }
  :global([data-theme="dark"]) .pin-window-body { background: var(--neutral-900); }

  @media (min-width: 1024px) {
    /* three-column timeline: text | centred icon (on the line) | browser mockup.
       text and mockup sit in opposite columns on the same row; they swap sides
       on alternating cards. */
    .pin-panel {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1fr) 56px minmax(0, 1fr);
      align-items: center; column-gap: 40px;
    }
    .pin-meta { display: contents; }                 /* icon + text become panel grid items */
    /* pin all three to row 1 so grid auto-placement can't bump any to a new row */
    .pin-panel .step-icon { grid-column: 2; grid-row: 1; justify-self: center; position: relative; z-index: 2; }
    /* connecting line: a gradient segment from each icon UP to the previous one.
       :not(:first-of-type) excludes the first icon of every section. */
    .pin-panel:not(:first-of-type) .step-icon::before {
      content: ''; position: absolute; left: 50%; transform: translateX(-50%);
      bottom: calc(100% + 6px); width: 3px; height: calc(100svh - 54px);
      border-radius: 2px; z-index: -1;
    }
    .step-teal .step-icon::before   { background: linear-gradient(180deg, var(--amber-500), var(--teal-500)); }
    .step-indigo .step-icon::before { background: linear-gradient(180deg, var(--teal-500), var(--indigo-500)); }

    .pin-meta-text { grid-column: 1; grid-row: 1; justify-self: end; text-align: right; max-width: 380px; }
    .pin-sub { max-width: none; }
    .pin-visual { grid-column: 3; grid-row: 1; justify-self: start; width: 100%; max-width: 460px; }

    /* every other card: text and mockup swap to the opposite columns (same row) */
    .pin-panel:nth-of-type(even) .pin-meta-text { grid-column: 3; justify-self: start; text-align: left; }
    .pin-panel:nth-of-type(even) .pin-visual { grid-column: 1; justify-self: end; }
  }

  /* ── Pinned mode (JS opt-in) ─────────────────────────────────────────── */
  .pin-section.pin-active { padding: 0; }
  .pin-section.pin-active .pin-track {
    height: calc((var(--pin-steps) + 1) * 100vh);
    height: calc((var(--pin-steps) + 1) * 100svh);
  }
  .pin-section.pin-active .pin-stage {
    position: sticky; top: 0;
    height: 100vh;
    height: 100svh;
  }
  .pin-section.pin-active .pin-stage-inner {
    height: 100%; display: flex; flex-direction: column; justify-content: center;
    padding-top: 76px; padding-bottom: 32px;
  }
  .pin-section.pin-active .pin-dots { display: flex; }
  .pin-section.pin-active .pin-deck { flex: 1 1 auto; min-height: 0; }
  .pin-section.pin-active .pin-panel {
    position: absolute; inset: 0; margin: 0;
    opacity: 0; transform: translateY(40px); pointer-events: none;
    transition: opacity 0.5s cubic-bezier(0.22,1,0.36,1), transform 0.5s cubic-bezier(0.22,1,0.36,1);
  }
  .pin-section.pin-active .pin-panel.is-active { opacity: 1; transform: translateY(0); pointer-events: auto; }
  .pin-section.pin-active .pin-panel.is-above { opacity: 0; transform: translateY(-48px); }
  .pin-section.pin-active .pin-panel.is-below { opacity: 0; transform: translateY(40px); }

  /* ── Demo-card interaction helpers (new classes only) ────────────────── */
  .bm-chip-empty { background: var(--surface-muted); color: var(--text-muted); }
  .bm-chip-loading { background: transparent; box-shadow: none; display: inline-flex; align-items: center; justify-content: center; min-width: 64px; padding: 3px 0; }
  /* .bm-chip-bar / .bm-chip-bar-fill live in global.css - created at runtime via innerHTML */
  .bm-chip.is-filling { animation: bmPop 0.3s ease; }
  @keyframes bmPop { 0% { transform: scale(0.85); } 60% { transform: scale(1.08); } 100% { transform: scale(1); } }
  .bm-result.is-in { animation: bmSlideIn 0.4s ease; }
  @keyframes bmSlideIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }
  /* hidden helpers inside any card (beats .bm-line / .bm-msg display) */
  .pin-window-body [hidden] { display: none; }
  /* completed action: a confirmation, not a pressable button */
  .bm-btn-done {
    background: none; border-color: transparent; box-shadow: none;
    color: var(--teal-700); font-weight: 700; cursor: default;
    padding-left: 0; padding-right: 0;
  }
  :global([data-theme="dark"]) .bm-btn-done { color: var(--teal-300); }
  /* .bm-scrollhint styles live in global.css so JS-created hints are styled */
  /* in-card confirmation message (Takes Initiative) */
  .bm-exec-confirm { margin-top: 12px; }
  .bm-exec-confirm.is-in { animation: bmSlideIn 0.4s ease; }
  .bm-switch[data-action] { border: 0; padding: 0; cursor: pointer; }

  /* You Stay In Control: segmented rule controls */
  .bm-permrow { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 9px 0; border-top: 1px solid var(--border); }
  .bm-permrow:first-of-type { border-top: 0; }
  .bm-permrow .bm-line-title { font-size: 0.82rem; }
  .bm-seg { display: inline-flex; background: var(--surface-muted); border-radius: var(--radius-full); padding: 3px; flex-shrink: 0; }
  .bm-seg-opt {
    border: 0; background: none; cursor: pointer;
    font-family: var(--font-mono); font-size: 0.66rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.03em;
    padding: 5px 11px; border-radius: var(--radius-full); color: var(--text-muted);
    transition: background 0.18s, color 0.18s;
  }
  .bm-seg-opt.is-active { background: var(--color-secondary); color: #fff; }
  .bm-card-foot { margin-top: 12px; font-size: 0.74rem; color: var(--teal-700); font-family: var(--font-mono); animation: bmSlideIn 0.35s ease; }
  :global([data-theme="dark"]) .bm-card-foot { color: var(--teal-200); }

  /* You Stay In Control: activity log */
  .bm-activity { display: flex; flex-direction: column; gap: 9px; margin: 4px 0 14px; }
  .bm-actline { display: flex; gap: 12px; align-items: baseline; font-size: 0.8rem; transition: opacity 0.3s ease; }
  .bm-actline.is-in { animation: bmSlideIn 0.35s ease; }
  .bm-actline .bm-time { flex-shrink: 0; width: 44px; }

  /* ── "This card is interactive" affordance ───────────────────────────── */
  /* per-step accent for the glow / hint */
  .pin-panel.step-amber  { --hint: 255,140,66; }
  .pin-panel.step-teal   { --hint: 23,190,187; }
  .pin-panel.step-indigo { --hint: 91,83,232; }
  /* glow only on the active, not-yet-used step's primary control */
  .pin-section.pin-active .pin-panel.is-active:not(.is-engaged) .bm-hint-target {
    animation: hintGlow 3.6s ease-in-out infinite;
  }
  /* each beat grows bigger than the last until a capped max, then rests and repeats */
  @keyframes hintGlow {
    0%   { box-shadow: 0 0 0 0  rgba(var(--hint), 0); }
    8%   { box-shadow: 0 0 0 4px  rgba(var(--hint), 0.20); }   /* beat 1 - small */
    18%  { box-shadow: 0 0 0 0  rgba(var(--hint), 0); }
    30%  { box-shadow: 0 0 0 8px  rgba(var(--hint), 0.26); }   /* beat 2 - medium */
    42%  { box-shadow: 0 0 0 0  rgba(var(--hint), 0); }
    56%  { box-shadow: 0 0 0 13px rgba(var(--hint), 0.30); }   /* beat 3 - max */
    70%  { box-shadow: 0 0 0 0  rgba(var(--hint), 0); }
    100% { box-shadow: 0 0 0 0  rgba(var(--hint), 0); }        /* brief rest, then repeat */
  }
  /* big "Press here" coachmark - right beside the first card's Prep button */
  .bm-press-wrap { position: relative; display: inline-flex; flex-shrink: 0; }
  .bm-presshere {
    position: absolute; top: 50%; right: calc(100% + 14px);
    transform: translateY(-50%);
    display: none; z-index: 6;
    background: var(--color-primary); color: var(--on-primary);
    font-family: var(--font-display); font-weight: 700; font-size: 1rem;
    padding: 7px 14px; border-radius: var(--radius-sm);
    box-shadow: var(--shadow-md); white-space: nowrap; pointer-events: none;
  }
  .bm-presshere::after {
    content: ''; position: absolute; left: 100%; top: 50%; transform: translateY(-50%);
    border: 7px solid transparent; border-left-color: var(--color-primary);
  }
  .pin-section.pin-active .pin-panel.is-active:not(.is-engaged) .bm-presshere {
    display: block; animation: pressBob 0.9s ease-in-out infinite;
  }
  /* nudge horizontally toward the button (keeps the vertical centering) */
  @keyframes pressBob {
    0%, 100% { transform: translateY(-50%) translateX(0); }
    50%      { transform: translateY(-50%) translateX(5px); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pin-section.pin-active .pin-panel.is-active:not(.is-engaged) .bm-hint-target { animation: none; box-shadow: 0 0 0 3px rgba(var(--hint), 0.22); }
    .pin-section.pin-active .pin-panel.is-active:not(.is-engaged) .bm-presshere { animation: none; }
  }
  .bm-todo { gap: 10px; }
  .bm-check {
    width: 18px; height: 18px; flex-shrink: 0; border-radius: var(--radius-full);
    border: 2px solid var(--border-strong); display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.25s, border-color 0.25s;
  }
  .bm-check::after { content: '✓'; font-size: 0.66rem; line-height: 1; color: #fff; opacity: 0; transition: opacity 0.2s; }
  .bm-check.is-done { background: var(--color-accent); border-color: var(--color-accent); }
  .bm-check.is-done::after { opacity: 1; }
  .bm-btn.is-busy { opacity: 0.75; cursor: default; }

  /* Morning-briefing: agenda + prep-detail flow */
  .bm-briefing [hidden] { display: none; }
  .bm-btn-sm { padding: 4px 12px; font-size: 0.72rem; flex-shrink: 0; }
  .bm-meeting { display: flex; align-items: center; gap: 10px; border-top: 1px solid var(--border); padding: 11px 0; }
  .bm-meeting:first-of-type { border-top: 0; }
  .bm-meeting .bm-line-title { flex: 1; }

  /* status bar */
  .bm-statusbar { padding: 4px 0 10px; animation: bmSlideIn 0.3s ease; }
  .bm-statusbar-track { height: 6px; border-radius: var(--radius-full); background: var(--surface-muted); overflow: hidden; }
  .bm-statusbar-fill { height: 100%; width: 0; border-radius: var(--radius-full); background: var(--color-primary); }
  .bm-statusbar-text { margin-top: 8px; font-size: 0.74rem; color: var(--text-secondary); font-family: var(--font-mono); }

  /* prep detail (card takeover) */
  .bm-back {
    background: none; border: 0; padding: 0; margin-bottom: 14px; cursor: pointer;
    font-family: var(--font-body); font-size: 0.78rem; color: var(--text-muted);
  }
  .bm-back:hover { color: var(--text-primary); }
  .bm-detail-title { display: flex; align-items: center; gap: 9px; margin-bottom: 16px; font-family: var(--font-display); font-weight: 700; font-size: 1.05rem; }
  .bm-detail-title .bm-time { font-size: 0.95rem; color: var(--text-muted); }
  .bm-detail-sep { color: var(--border-strong); font-weight: 400; }
  .bm-prep-brief { display: flex; flex-direction: column; gap: 9px; }
  .bm-prep-row { display: flex; gap: 12px; font-size: 0.82rem; line-height: 1.45; }
  .bm-prep-key {
    flex-shrink: 0; width: 80px; font-family: var(--font-mono); font-size: 0.66rem;
    text-transform: uppercase; letter-spacing: 0.04em; color: var(--text-muted); padding-top: 2px;
  }
  .bm-prep-brief + .bm-actions { margin-top: 16px; }
  .bm-btn-spin {
    display: inline-block; width: 12px; height: 12px; margin-right: 7px; vertical-align: -1px;
    border-radius: var(--radius-full);
    border: 2px solid rgba(0,0,0,0.2); border-top-color: currentColor;
    animation: bmSpin 0.6s linear infinite;
  }
  @keyframes bmSpin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .bm-btn-spin { animation: none; } }

  /* Zero admin backlog: checklist + execute / close */
  [data-backlog] [hidden] { display: none; }
  [data-backlog-card] { gap: 0; }
  [data-backlog-card] .bm-card-head { padding-bottom: 4px; }
  .bm-task {
    display: flex; align-items: center; gap: 11px; cursor: pointer;
    border-top: 1px solid var(--border); padding: 11px 0;
  }
  .bm-task:first-of-type { border-top: 0; }
  .bm-checkbox { position: absolute; opacity: 0; width: 0; height: 0; }
  .bm-task-box {
    flex-shrink: 0; width: 19px; height: 19px; border-radius: var(--radius-xs);
    border: 2px solid var(--border-strong); display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.15s, border-color 0.15s;
  }
  .bm-task-box::after { content: '✓'; font-size: 0.72rem; line-height: 1; color: #fff; opacity: 0; transition: opacity 0.15s; }
  .bm-checkbox:checked + .bm-task-box { background: var(--color-secondary); border-color: var(--color-secondary); }
  .bm-checkbox:checked + .bm-task-box::after { opacity: 1; }
  .bm-checkbox:focus-visible + .bm-task-box { outline: 2px solid var(--color-secondary); outline-offset: 2px; }
  .bm-task .bm-line-title { flex: 1; transition: color 0.2s; }
  .bm-task.is-done { cursor: default; }
  .bm-task.is-done .bm-task-box { background: var(--color-accent); border-color: var(--color-accent); }
  .bm-task.is-done .bm-line-title { color: var(--text-muted); text-decoration: line-through; }

  .bm-backlog-actions { display: flex; align-items: center; justify-content: space-between; gap: 12px; margin-top: 14px; }
  .bm-btn:disabled { opacity: 0.45; cursor: not-allowed; }
  .bm-textbtn {
    background: none; border: 0; padding: 6px 4px; cursor: pointer;
    font-family: var(--font-body); font-size: 0.8rem; color: var(--text-muted);
  }
  .bm-textbtn:hover { color: var(--text-primary); }
  .bm-backlog-collapsed { flex-direction: row; align-items: center; justify-content: space-between; gap: 12px; }
  .bm-backlog-collapsed .bm-line-title { color: var(--text-secondary); font-size: 0.85rem; }
  .bm-backlog-collapsed.is-complete {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }
  .bm-backlog-collapsed.is-complete .bm-line-title {
    color: var(--teal-700); font-weight: 600;
    display: inline-flex; align-items: center; gap: 8px;
  }
  .bm-backlog-collapsed.is-complete .bm-line-title::before {
    content: '✓'; flex-shrink: 0;
    width: 18px; height: 18px; border-radius: var(--radius-full);
    background: var(--color-accent); color: #fff;
    font-size: 0.7rem; line-height: 1;
    display: inline-flex; align-items: center; justify-content: center;
  }
  :global([data-theme="dark"]) .bm-backlog-collapsed.is-complete .bm-line-title { color: var(--teal-200); }

  @media (prefers-reduced-motion: reduce) {
    .pin-section.pin-active { padding: 96px 0; }
    .pin-section.pin-active .pin-track { height: auto !important; }
    .pin-section.pin-active .pin-stage { position: static; height: auto; }
    .pin-section.pin-active .pin-stage-inner { display: block; padding-top: 0; }
    .pin-section.pin-active .pin-dots { display: none; }
    .pin-section.pin-active .pin-panel {
      position: static; inset: auto; opacity: 1; transform: none;
      pointer-events: auto; margin-bottom: 48px;
    }
  }

  /* ── Coming soon ─────────────────────────────────────────────────────── */
  .coming-soon-section {
    padding: 80px 0;
    border-bottom: 1px solid var(--border);
  }
  .coming-card {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
    background: var(--surface-subtle);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: 56px 40px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .coming-card::before {
    content: "";
    position: absolute;
    inset: 0;
    background: var(--gradient-soft);
    opacity: 0.5;
    pointer-events: none;
  }
  .coming-card > * { position: relative; z-index: 1; }
  .coming-badge {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--indigo-600);
    background: var(--color-secondary-soft);
    border: 1px solid var(--indigo-200);
    padding: 5px 14px;
    border-radius: var(--radius-full);
    display: inline-block;
  }
  :global([data-theme="dark"]) .coming-badge {
    color: #FFFFFF !important;
    border-color: rgba(255, 255, 255, 0.5);
    background: transparent;
  }
  .coming-card h2 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
  }
  .coming-title { color: var(--amber-500); }
  .coming-card p {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 420px;
    line-height: 1.7;
  }
  .btn-outline-lg {
    display: inline-block;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.65rem 1.4rem;
    border-radius: var(--radius-sm);
    border: 1.5px solid var(--color-primary);
    color: var(--color-primary-text);
