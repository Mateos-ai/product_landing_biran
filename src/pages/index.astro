  .imagine-hl { color: var(--amber-500); }
  .imagine-hl-teal { color: var(--teal-400); }
  .imagine-hl-purple { color: var(--indigo-400); }
  .imagine-hl-gradient { background: var(--gradient-brand); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; }

  /* ── Approach / journey ──────────────────────────────────────────────── */
  .approach-section { padding: 104px 0; background: var(--surface); border-bottom: 1px solid var(--border); }
  .journey {
    position: relative; border-radius: var(--radius-xl); padding: 46px 28px 34px; margin-bottom: 64px;
    background:
      linear-gradient(var(--surface), var(--surface)) padding-box,
      var(--gradient-brand) border-box;
    border: 1.5px solid transparent;
  }
  .journey-wrap-label {
    position: absolute; top: 0; left: 50%; transform: translate(-50%, -50%);
    display: inline-flex; align-items: center; gap: 9px; white-space: nowrap;
    background: var(--surface); border: 1px solid var(--border-strong); border-radius: var(--radius-full);
    padding: 8px 18px; font-family: var(--font-mono); font-size: 0.72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-secondary);
